set terminal pngcairo size 1000,600 enhanced font "Arial,10"
set output "graficos/casos_por_ano.png"

set datafile separator ";"
set title "Casos de SRAG por ano"
set xlabel "Ano"
set ylabel "Casos"
set grid ytics
set key off
set style fill solid 0.75 border -1
set boxwidth 0.6
set yrange [0:*]

plot "dados/tratados/casos_por_ano.csv" every ::1 using 2:xtic(1) with boxes lc rgb "#2f6f9f"
