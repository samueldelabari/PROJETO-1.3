set terminal pngcairo size 1000,600 enhanced font "Arial,10"
set output "graficos/obitos_por_ano.png"

set datafile separator ";"
set title "Obitos de SRAG por ano"
set xlabel "Ano"
set ylabel "Obitos"
set grid ytics
set key off
set style fill solid 0.75 border -1
set boxwidth 0.6
set yrange [0:*]

plot "dados/tratados/obitos_por_ano.csv" every ::1 using 2:xtic(1) with boxes lc rgb "#9f2f2f"
